#!/usr/bin/env bash

export PATH="$(dirname "$0"):$PATH"

cmd="$1"

case "$cmd" in
"")
    if command -v peco >/dev/null 2>&1; then
        selected_license=$(licenses-list | peco)
        if [[ -n "$selected_license" ]]; then
            licenses-get "$selected_license"
        fi
    else
        printf 'error: peco is not installed. Install peco or run: %s <license-id>\n' "${0##*/}" >&2
        exit 1
    fi
    ;;
list)
    licenses-list
    ;;
get)
    licenses-get "$2"
    ;;
update)
    licenses-update
    ;;
-h | --help | help)
    cat <<EOF
usage: ${0##*/} [command | license-id]

commands:
  (empty) - interactive selection using peco
  list   - list available licenses (local cache)
  get    - copy a license to LICENSE file
  update - download/sync all available licenses

shorthand:
  ${0##*/} <license-id>  (alias for get)

example usage:
  ${0##*/} update
  ${0##*/} list
  ${0##*/} mit
EOF
    exit 0
    ;;
*)
    licenses-get "$cmd"
    ;;
esac
